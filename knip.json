{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "project": ["**/*.{js,mjs,cjs,jsx,ts,tsx,mts,cts}"],
  "ignore": [
    "**/__fixtures__/**",
    ".pi/extensions/n-cursor-adr/**",
    "app/src-tauri/target/**",
    "scripts/docs-regen/manifest.js",
    "scripts/docs-regen/marks.js"
  ],
  "ignoreDependencies": [
    "@nitra/cspell-dict",
    "/@cspell\\/dict-.+/",
    "graphql",
    "@nitra/stylelint-config",
    "@stryker-mutator/command-runner"
  ],
  "ignoreExportsUsedInFile": true,
  "ignoreBinaries": [
    "actionlint",
    "cspell",
    "eslint",
    "git-ai",
    "jscpd",
    "markdownlint-cli2",
    "oxfmt",
    "oxlint",
    "shellcheck",
    "stylelint",
    "trufflehog",
    "uvx",
    "v8r",
    "zizmor"
  ],
  "workspaces": {
    ".": {
      "entry": [
        "eslint.config.{js,mjs,cjs}",
        "stylelint.config.{js,cjs,mjs}",
        "oxlint.config.{js,mjs}",
        "jscpd.config.{js,mjs}",
        "markdownlint-cli2.config.{js,mjs,cjs,jsonc}",
        ".markdownlint-cli2.{jsonc,cjs,mjs}",
        "commitlint.config.{js,cjs,mjs}"
      ]
    },
    "app": {
      "entry": ["src/**/*.test.js", "test/happy-dom.preload.js"]
    }
  }
}
