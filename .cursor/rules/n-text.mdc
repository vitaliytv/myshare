```json
{
  "top-level": {
    "prettier": "Prettier заборонено — використовуй oxfmt (text.mdc)"
  },
  "dependencies": {
    "prettier": "Prettier заборонено — використовуй oxfmt (text.mdc)",
    "@nitra/prettier-config": "Prettier-конфіг заборонено — використовуй oxfmt (text.mdc)",
    "markdownlint-cli2": "використовуй bunx у lint-text (text.mdc)"
  },
  "devDependencies": {
