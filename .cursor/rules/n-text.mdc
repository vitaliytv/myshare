    "MD029": false,
    "MD040": false,
    "MD041": false
  }
}
```
- `.cspell.json`:

```json
{
  "version": "0.2",
  "useGitignore": true,
  "gitignoreRoot": ".",
  "ignorePaths": [
    "**/node_modules/**",
    "**/vscode-extension/**",
