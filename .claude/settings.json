{
  "permissions": {
    "allow": [
      "Bash(bun *)",
      "Bash(bun run *)",
      "Bash(bun test *)",
      "Bash(bunx *)",
      "Bash(npx --no @nitra/cursor *)",
      "Bash(npx @nitra/cursor *)",
      "Bash(npx --no @7n/rules *)",
      "Bash(npx @7n/rules *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/capture-decisions.sh\"",
            "async": true,
            "timeout": 180
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/normalize-decisions.sh\"",
            "async": true,
            "timeout": 600
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npx --no @7n/rules hook --post-tool-use",
            "timeout": 300
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "command -v rtk >/dev/null 2>&1 && exec rtk hook claude; exit 0",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
